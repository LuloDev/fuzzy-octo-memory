# Alpaca (paper defaults — override for live)
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_BASE_URL=https://paper-api.alpaca.markets
# Market data URL (same for paper and live)
APCA_DATA_URL=https://data.alpaca.markets

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (SQLite default)
DATABASE_URL=file:./prisma/dev.db

# Behavior
DRY_RUN=true
MONITOR_INTERVAL_MS=300000
DAILY_LOSS_LIMIT=-0.03
PANIC_REQUIRES_CONFIRMATION=false

# Server
PORT=3000
# Bind to 0.0.0.0 so the port is reachable from outside the process/container.
# Use 127.0.0.1 only for bare-metal runs where you want loopback-only access.
HOST=0.0.0.0